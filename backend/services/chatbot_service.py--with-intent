from backend.services.order_service import (
    create_order
)

def handle_place_order(
    db,
    user_id
):

    result = create_order(
        db,
        user_id
    )

    return {
        "type": "PLACE_ORDER",
        "data": result
    }



from backend.services.cart_service import (
    add_to_cart
)

def handle_add_to_cart(
    db,
    user_id,
    message
):

    products = semantic_search(
        query=message,
        top_k=1
    )

    if not products:

        return {
            "message":
            "No product found"
        }

    product_id = int(
        products[0]["product_id"]
    )

    return add_to_cart(
        db,
        user_id,
        product_id,
        1
    )